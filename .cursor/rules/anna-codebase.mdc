## 新增插件形状：完整步骤

### 步骤 1：创建 `plugins/basic/myShape.js`

**方案 A — 多边形（用顶点坐标描述轮廓）**

```javascript
import {rectangle} from "@anna/core/shapes/rectangle.js";
import {canvasGeometryDrawer} from "@anna/core/drawers/canvasGeometryDrawer.js";

const canvasMyShapeDrawer = (shape, div, x, y) => {
    const self = canvasGeometryDrawer(shape, div, x, y);
    self.drawBorder = () => {};       // 必须抑制，否则重复渲染
    self.backgroundRefresh = () => {};// 必须抑制

    self.getPoints = (px, py) => {
        const w = shape.width, h = shape.height;
        // 顶点按屏幕坐标顺时针排列（y 轴向下）
        return [
            [px,     py],
            [px + w, py],
            [px + w, py + h],
            [px,     py + h],
        ];
    };

    self.requireMoveToStart = () => true;  // 第一个点用 moveTo
    return self;
};

const myShape = (id, x, y, width, height, parent) => {
    let self = rectangle(id, x, y, width, height, parent, canvasMyShapeDrawer);
    self.width  = 100;
    self.height = 80;
    self.type   = "myShape";   // ⚠️ 必须全局唯一
    self.text   = "";

    const getConfigurations = self.getConfigurations;
    self.getConfigurations = () => {
        const configurations = getConfigurations.apply(self);
        configurations.remove(c => c.field === "cornerRadius"); // 不支持圆角时移除
        return configurations;
    };
    return self;
};

export {myShape};
```

**方案 B — 图标形状（自定义 canvas 绘制）**

```javascript
const canvasMyIconDrawer = (shape, div, x, y) => {
    const self = canvasGeometryDrawer(shape, div, x, y);
    self.drawBorder = () => {};
    self.backgroundRefresh = () => {};

    self.drawStatic = (context, px, py) => {
        // 坐标约定：px = shape.margin ≈ 1，py = shape.margin ≈ 1
        // 有效绘制区：(px, py) 起点，(shape.width - 2) × (shape.height - 2) 大小
        const W      = shape.width  - 2;
        const H      = shape.height - 2;
        const bw     = shape.borderWidth || 1.5;
        const fill   = shape.getBackColor();
        const stroke = shape.getBorderColor();

        context.save();
        context.lineWidth   = bw;
        context.strokeStyle = stroke;
        context.fillStyle   = fill;

        // ... 用 canvas API 绘制 ...
        context.beginPath();
        context.roundRect(px, py, W, H, 8);
        context.fill();
        context.stroke();

        context.restore();
    };

    self.getPoints = () => [];  // 自定义 drawStatic 时置空
    return self;
};
```

