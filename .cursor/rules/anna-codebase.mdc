## 引擎初始化（完整流程）

```javascript
import {graph} from '@anna/core/base/graph.js';

const g = graph(canvasDiv, 'My Board');   // 创建图形引擎
g.login({name: 'User', id: 'user-id'});  // 必须 login
g.collaboration.mute = true;             // 单机模式关闭协同
g.enableText = false;                    // 关闭文字编辑

// 注册所有形状模块（顺序无关）
for (const mod of SHAPE_MODULES) {
    await g.dynamicImportStatement(() => Promise.resolve(mod));
}

if (g.loadConfig) g.loadConfig();        // 加载配置（可选）

const page = g.addPage('Page 1', undefined, canvasDiv);  // 创建页面
```

