## 主题系统（whiteboard.js）

```javascript
// 三套画布主题，currentThemeIndex 控制当前激活
const CANVAS_THEMES = [
    { id: 'light', canvasBg: '#c8c5c0', shapeBackColor: '#ffffff', shapeBorderColor: '#a8b2c4' },
    { id: 'dark',  canvasBg: '#2a2d3a', shapeBackColor: '#3a3d4a', shapeBorderColor: '#5a5f78' },
    { id: 'warm',  canvasBg: '#f0ece6', shapeBackColor: '#ffffff', shapeBorderColor: '#b8a898' },
];

// THEME 通过 getter 动态读取当前主题
const THEME = {
    get canvasBg()         { return CANVAS_THEMES[currentThemeIndex].canvasBg; },
    get shapeBackColor()   { return CANVAS_THEMES[currentThemeIndex].shapeBackColor; },
    get shapeBorderColor() { return CANVAS_THEMES[currentThemeIndex].shapeBorderColor; },
    shapeBorderWidth: 1.5,
    penColor: '#7a8499',
    penWidth: 2,
};

// 切换主题：currentThemeIndex++ % 3，然后调用 applyCanvasTheme()
// applyCanvasTheme() 直接设置 canvasDiv.style.background
```

